E2E_BASE_URL=http://localhost:4200
E2E_BACKEND_API_BASE_URL=http://localhost:3000/api
E2E_HEADLESS=true
E2E_TIMEOUT_MS=30000

# Optional process management (set true to let the framework start services)
E2E_START_FRONTEND=false
E2E_FRONTEND_CMD=npm run start
E2E_FRONTEND_CWD=..
E2E_FRONTEND_WAIT_ON=http://localhost:4200

E2E_START_BACKEND=false
E2E_BACKEND_CMD=npm run start:server
E2E_BACKEND_CWD=..
E2E_BACKEND_WAIT_ON=http://localhost:3000/api/health

# Optional SQL DB assertions (supported dialects: postgres, mysql, mssql)
E2E_DB_DIALECT=postgres
E2E_DB_HOST=localhost
E2E_DB_PORT=5432
E2E_DB_NAME=furniture
E2E_DB_USER=furniture
E2E_DB_PASSWORD=change-me
E2E_DB_ENCRYPT=false
