{
  "name": "furniture-e2e-tests",
  "version": "0.1.0",
  "private": true,
  "description": "BDD end-to-end tests for DIY Furniture (frontend + backend + DB assertions)",
  "scripts": {
    "pretest": "node scripts/verify-local-install.js",
    "pretest:smoke": "node scripts/verify-local-install.js",
    "pretest:yaml": "node scripts/verify-local-install.js",
    "pretest:headed": "node scripts/verify-local-install.js",
    "test": "cucumber-js -p default",
    "test:smoke": "cross-env E2E_START_FRONTEND=true E2E_START_BACKEND=true cucumber-js -p smoke",
    "test:smoke:manual": "cucumber-js -p smoke",
    "test:yaml": "cross-env E2E_START_FRONTEND=true E2E_START_BACKEND=true cucumber-js -p default --tags \"@yaml and not @manual\"",
    "test:db": "cucumber-js -p default --tags \"@db and not @manual\"",
    "test:headed": "cross-env E2E_HEADLESS=false cucumber-js -p default",
    "check": "tsc -p tsconfig.json --noEmit",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "playwright": "^1.51.1",
    "tree-kill": "^1.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "wait-on": "^9.0.1",
    "yaml": "^2.7.1"
  },
  "optionalDependencies": {
    "mssql": "^11.0.1",
    "mysql2": "^3.14.0",
    "pg": "^8.14.1"
  }
}
